---

<Layout
	title="Rebooted Creative Lab | Creative Education with OttoNinja"
	description="Creative education hub for OttoNinja robotics, wearable electronics, and playful curriculum resources."
>
	<main class="site">
		<section class="hero" id="hero">
			<div class="hero__content">
				<p class="eyebrow" data-i18n><I18nText translations={heroCopy.eyebrow} /></p>
				<h1 data-i18n><I18nText translations={heroCopy.heading} /></h1>
				<p class="lede" data-i18n><I18nText translations={heroCopy.lede} /></p>
				<div class="hero__cta">
					<a class="solid" href="#projects" data-i18n><I18nText translations={heroCopy.ctaSolid} /></a>
					<a class="ghost" href="#resources" data-i18n><I18nText translations={heroCopy.ctaGhost} /></a>
				</div>
				<div class="hero__stats">
					{heroCopy.stats.map((stat) => (
						<div>
							<strong>{stat.value}</strong>
							<span data-i18n><I18nText translations={stat.label} /></span>
						</div>
					))}
				</div>
			</div>
			<div class="hero__panel" aria-label="Featured kit signal">
				<div class="panel__grid">
					<div class="panel__card">
						<p class="panel__label" data-i18n><I18nText translations={heroPanel.liveFeedLabel} /></p>
						{heroPanel.liveOutputs.map((output) => (
							<output data-i18n><I18nText translations={output} /></output>
						))}
					</div>
					<div class="panel__card panel__card--accent">
						<p class="panel__label" data-i18n><I18nText translations={heroPanel.presetLabel} /></p>
						<ul>
							{heroPanel.presetItems.map((item) => (
								<li data-i18n><I18nText translations={item} /></li>
							))}
						</ul>
					</div>
					<div class="panel__card">
						<p class="panel__label" data-i18n><I18nText translations={heroPanel.checklistLabel} /></p>
						<ul class="checklist">
							{heroPanel.checklistItems.map((item) => (
								<li data-i18n><I18nText translations={item} /></li>
							))}
						</ul>
					</div>
				</div>
			</div>
		</section>

		<section class="projects" id="projects">
			<header>
				<p class="eyebrow" data-i18n><I18nText translations={sectionCopy.projects.eyebrow} /></p>
				<h2 data-i18n><I18nText translations={sectionCopy.projects.heading} /></h2>
				<p data-i18n><I18nText translations={sectionCopy.projects.body} /></p>
			</header>
			<div class="card-grid">
				{projectCards.map((project) => (
					<article class="project-card">
						<div class="project-card__meta">
							<span data-i18n><I18nText translations={project.focus} /></span>
							<span data-i18n><I18nText translations={project.duration} /></span>
						</div>
						<h3 data-i18n><I18nText translations={project.title} /></h3>
						<p data-i18n><I18nText translations={project.description} /></p>
						<ul>
							{project.kits.map((kit) => (
								<li data-i18n><I18nText translations={kit} /></li>
							))}
						</ul>
					</article>
				))}
			</div>
		</section>

		<section class="kits" id="kits">
			<div class="kits__intro">
				<div>
					<p class="eyebrow" data-i18n><I18nText translations={sectionCopy.kits.eyebrow} /></p>
					<h2 data-i18n><I18nText translations={sectionCopy.kits.heading} /></h2>
					<p data-i18n><I18nText translations={sectionCopy.kits.body} /></p>
				</div>
				<div class="kits__note">
					<strong data-i18n><I18nText translations={sectionCopy.kits.tipLabel} /></strong>
					<p data-i18n><I18nText translations={sectionCopy.kits.tipBody} /></p>
				</div>
			</div>
			<div class="kit-grid">
				{kitList.map((kit) => (
					<div class="kit-card" style={{ '--chip-color': kit.color }}>
						<h3 data-i18n><I18nText translations={kit.name} /></h3>
						<p class="kit-card__chips" data-i18n><I18nText translations={kit.chips} /></p>
						<p data-i18n><I18nText translations={kit.useCase} /></p>
					</div>
				))}
			</div>
		</section>

		<section class="timeline" id="curriculum">
			<header>
				<p class="eyebrow" data-i18n><I18nText translations={sectionCopy.timeline.eyebrow} /></p>
				<h2 data-i18n><I18nText translations={sectionCopy.timeline.heading} /></h2>
			</header>
			<ol>
				{timeline.map((step, index) => (
					<li>
						<div class="dot">{index + 1}</div>
						<div>
							<h3 data-i18n><I18nText translations={step.phase} /></h3>
							<p class="theme" data-i18n><I18nText translations={step.theme} /></p>
							<p class="outputs" data-i18n><I18nText translations={step.outputs} /></p>
						</div>
					</li>
				))}
			</ol>
		</section>

		<section class="field-notes" id="stories">
			<header>
				<p class="eyebrow" data-i18n><I18nText translations={sectionCopy.fieldNotes.eyebrow} /></p>
				<h2 data-i18n><I18nText translations={sectionCopy.fieldNotes.heading} /></h2>
				<p data-i18n><I18nText translations={sectionCopy.fieldNotes.body} /></p>
			</header>
			<div class="note-grid">
				{fieldNotes.map((note) => (
					<article class="note-card" style={{ '--note-accent': note.accent }}>
						<span class="note-card__pulse" aria-hidden="true"></span>
						<div class="note-card__meta">
							<span data-i18n><I18nText translations={note.location} /></span>
							<div class="note-card__tags">
								{note.tags.map((tag) => (
									<span data-i18n><I18nText translations={tag} /></span>
								))}
							</div>
						</div>
						<h3 data-i18n><I18nText translations={note.title} /></h3>
						<p data-i18n><I18nText translations={note.story} /></p>
						<div class="note-card__impact">
							<strong>{note.impactStat}</strong>
							<span data-i18n><I18nText translations={note.impactLabel} /></span>
						</div>
						<div class="note-card__system">
							<div>
								<span data-i18n><I18nText translations={text('Kitmix', 'Kit mix', 'Mezcla de kits', 'Mix de kits')} /></span>
								<p data-i18n><I18nText translations={note.kitMix} /></p>
							</div>
							<div>
								<span data-i18n><I18nText translations={text('Ritueel', 'Ritual', 'Ritual', 'Rituel')} /></span>
								<p data-i18n><I18nText translations={note.ritual} /></p>
							</div>
						</div>
						<ul>
							{note.highlights.map((highlight) => (
								<li data-i18n><I18nText translations={highlight} /></li>
							))}
						</ul>
					</article>
				))}
			</div>
		</section>

		<section class="support" id="support">
			<div class="support__intro">
				<p class="eyebrow" data-i18n><I18nText translations={sectionCopy.support.eyebrow} /></p>
				<h2 data-i18n><I18nText translations={sectionCopy.support.heading} /></h2>
				<p data-i18n><I18nText translations={sectionCopy.support.body} /></p>
				<div class="support__badge">
					{sectionCopy.support.badges.map((badge) => (
						<span data-i18n><I18nText translations={badge} /></span>
					))}
				</div>
				<a class="ghost" href="#connect" data-i18n><I18nText translations={sectionCopy.support.cta} /></a>
			</div>
			<div class="support__tracks">
				{supportTracks.map((track) => (
					<article style={{ '--track-accent': track.accent }}>
						<header>
							<h3 data-i18n><I18nText translations={track.title} /></h3>
							<span class="support__duration" data-i18n><I18nText translations={track.duration} /></span>
						</header>
						<p data-i18n><I18nText translations={track.summary} /></p>
						<ul class="support__deliverables">
							{track.deliverables.map((item) => (
								<li data-i18n><I18nText translations={item} /></li>
							))}
						</ul>
						<ul class="support__touchpoints">
							{track.touchpoints.map((step) => (
								<li>
									<strong data-i18n><I18nText translations={step.label} /></strong>
									<span data-i18n><I18nText translations={step.detail} /></span>
								</li>
							))}
						</ul>
						<p class="support__signal" data-i18n><I18nText translations={track.signal} /></p>
					</article>
				))}
			</div>
		</section>

		<section class="resources" id="resources">
			<header>
				<p class="eyebrow" data-i18n><I18nText translations={sectionCopy.resources.eyebrow} /></p>
				<h2 data-i18n><I18nText translations={sectionCopy.resources.heading} /></h2>
			</header>
			<div class="resource-grid">
				{resourceHighlights.map((resource) => (
					<article>
						<h3 data-i18n><I18nText translations={resource.title} /></h3>
						<p data-i18n><I18nText translations={resource.copy} /></p>
						<a href={resource.link} data-i18n><I18nText translations={sectionCopy.resources.cta} /></a>
					</article>
				))}
			</div>
		</section>

		<section class="cta" id="connect">
			<div>
				<p class="eyebrow" data-i18n><I18nText translations={sectionCopy.cta.eyebrow} /></p>
				<h2 data-i18n><I18nText translations={sectionCopy.cta.heading} /></h2>
				<p data-i18n><I18nText translations={sectionCopy.cta.body} /></p>
			</div>
			<a class="solid" href="mailto:hello@rebooted.education" data-i18n><I18nText translations={sectionCopy.cta.cta} /></a>
		</section>
	</main>
</Layout>

<style>
	:global(body) {
		background: radial-gradient(circle at top right, rgba(255, 255, 255, 0.25), transparent 45%)
			0 0 / 240px 240px,
			var(--page-surface);
	}

	.site {
		display: flex;
		flex-direction: column;
		gap: 5rem;
		padding: clamp(1.75rem, 3vw, 3rem) clamp(1rem, 5vw, 5rem) 4rem;
	}

	section {
		background: rgba(255, 255, 255, 0.07);
		border: 1px solid rgba(255, 255, 255, 0.15);
		border-radius: 28px;
		padding: clamp(1.75rem, 2vw, 2.5rem);
		box-shadow: 0 30px 80px rgba(15, 29, 49, 0.18);
		scroll-margin-top: 140px;
	}

	.hero {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		align-items: center;
		gap: 2rem;
		background: radial-gradient(circle at 15% 30%, rgba(255, 255, 255, 0.25), transparent 55%),
			linear-gradient(125deg, rgba(255, 165, 117, 0.4), rgba(93, 224, 182, 0.25));
